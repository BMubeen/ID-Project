<script>
  // Quiz logic
  let answers = {};
  let currentStep = 1;

  document.querySelectorAll('.quiz-option').forEach(btn => {
    btn.addEventListener('click', function() {
      const step = this.closest('.quiz-step');
      step.querySelectorAll('.quiz-option').forEach(b => b.classList.remove('selected'));
      this.classList.add('selected');

      const stepNum = step.id.replace('step', '');
      answers['q' + stepNum] = this.dataset.value;

      step.querySelector('.quiz-next').classList.add('visible');
    });
  });

  document.getElementById('next1').addEventListener('click', () => goToStep(2));
  document.getElementById('next2').addEventListener('click', () => goToStep(3));
  document.getElementById('next3').addEventListener('click', () => showResult());

  function goToStep(n) {
    document.querySelector('.quiz-step.active').classList.remove('active');
    document.getElementById('step' + n).classList.add('active');
    currentStep = n;
  }

  function showResult() {
    const edu = answers.q1;
    const origin = answers.q2;
    const prof = answers.q3;

    let era, title, desc, verdict;

    // 1885 era: Chinese or Asian + labour/professional
    if (origin === 'china') {
      if (prof === 'labour') {
        era = '1881–1885 · The Railway Era';
        title = 'CPR Construction Labourer — $1/Day';
        desc = 'Canada recruited you directly from Guangdong province to blast through the Rocky Mountains. You are assigned the most dangerous tasks: drilling, placing explosives, hanging from rope baskets over cliffs. You receive no food, no shelter, no medical care from the CPR. You work alongside white workers who earn twice your wage for the same or safer work.';
        verdict = 'When the railway is complete in 1885, the Canadian government passes the Chinese Immigration Act. A $50 head tax — nearly two months\' wages — is imposed on any Chinese person entering Canada. By 1903, it is $500. By 1923, Chinese immigration is effectively banned entirely. The country you built does not want you to stay.';
      } else if (prof === 'professional' || prof === 'skilled') {
        era = '1885–1923 · The Exclusion Era';
        title = 'Excluded — Head Tax Required';
        desc = 'Your profession and qualifications are irrelevant. China is the only country whose citizens must pay a fee — initially $50, eventually $500 — to enter Canada. The 1923 Chinese Immigration Act then bans nearly all Chinese immigration. Fewer than 50 Chinese immigrants will be admitted to Canada in the next 24 years.';
        verdict = 'Your credentials, skills, and ambitions do not factor into Canada\'s decision. Your country of origin determines your fate. This is not an accident — it is the explicit, stated policy of the Government of Canada.';
      } else {
        era = '1885–1923 · The Exclusion Era';
        title = 'Subject to the Head Tax';
        desc = 'Regardless of your profession or education, you must pay the Chinese Head Tax to enter Canada — $50 initially (1885), raised to $100 (1900) and $500 (1903). The tax is equivalent to roughly two years\' wages for a railway worker.';
        verdict = 'Chinese Canadians who served in World War II fought for and won the right to citizenship in 1947. Canada\'s formal apology for the Head Tax came 59 years later, in 2006.';
      }
    }

    // 1896–1914: prairie settler era
    else if (origin === 'ukraine' && (prof === 'farmer' || prof === 'labour')) {
      era = '1896–1914 · The Prairie Settlement Era';
      title = 'Ukrainian Homesteader — 160 Acres of Prairie';
      desc = 'You are exactly the immigrant Clifford Sifton wanted: an experienced farmer from the Austro-Hungarian Empire, accustomed to harsh conditions, willing to break prairie sod. The Canadian government has distributed pamphlets in your village advertising "The Last Best West." You are offered 160 acres of free land under the Dominion Lands Act, if you agree to farm it.';
      verdict = 'Your settlement creates the communities that will eventually become Winnipeg\'s North End. The Ukrainian Canadian presence on the prairies is one of the most lasting legacies of Sifton\'s campaign. But during WWI, you and 80,000 other Ukrainian Canadians will be classified as "enemy aliens" and some interned, despite your contribution to building the country.';
    }

    else if (origin === 'uk' && prof === 'domestic') {
      era = '1899–1929 · The Domestic Servant Era';
      title = 'Domestic Servant — Government Recruited';
      desc = 'You are a single British woman between 17 and 35. Canada\'s Immigration Branch, working with organizations like the Girls\' Friendly Society, has recruited you specifically for domestic work. You are placed with a family — in Winnipeg, in Toronto, in Vancouver — as a household servant. In 1906, 4,467 women like you entered Canada this way.';
      verdict = 'The work is low-paid and exploitative. You have limited legal protections. If you become pregnant outside marriage, you risk deportation. The Canadian government has imported your labour, but not designed a system to support your wellbeing or advancement.';
    }

    else if (origin === 'uk' && (prof === 'farmer' || prof === 'labour')) {
      era = '1896–1914 · The Prairie Settlement Era';
      title = 'British Settler — Preferred Category';
      desc = 'You are welcomed enthusiastically. British immigrants were the most desirable in Sifton\'s hierarchy. More than half of the two million settlers who arrived between 1896 and 1914 were from the British Isles. You are settled on the prairies and given access to homestead land.';
      verdict = 'You are one of the lucky ones — your origin country, your ethnicity, and your profession align perfectly with what Canada wanted from immigration in this era.';
    }

    // 1967 points system era: South Asian or African + professional
    else if ((origin === 'india' || origin === 'africa') && prof === 'professional' && edu === 'grad') {
      era = '1967–2000 · The Points System Era';
      title = 'Admitted — But Can You Practice?';
      desc = 'The 1967 Points System has removed the racial barriers that would have excluded you before. You score well: graduate degree (+12 points), professional training (+15 points), English proficiency (+10 points), age (+10 points). You qualify as an independent immigrant and are admitted to Canada. You arrive with a medical degree, or an engineering degree, or a law degree earned after years of study.';
      verdict = 'Then you discover that your credential must be assessed by a provincial licensing body. The process takes 1–3 years, costs thousands of dollars, and may require you to repeat portions of your training. While you wait, you take whatever work you can find. Canada selected you for your skills. Canada does not have a system to use them.';
    }

    else if ((origin === 'india' || origin === 'africa') && prof === 'professional') {
      era = '2000s–2025 · The Brain Waste Era';
      title = 'Admitted — Overqualified, Underemployed';
      desc = 'You were selected through Express Entry based on your professional credentials. Canada scored you highly. You arrived. Now you are applying for jobs and being told you lack "Canadian experience." Your degree is recognized in principle but you still need licensing, which requires Canadian references, which you cannot get without Canadian experience. It is a circle with no entry point.';
      verdict = 'According to the C.D. Howe Institute (2025), you will earn on average 46% less than a non-immigrant in your field. 25% of immigrants with foreign degrees work in jobs requiring only a high school diploma. You are three times more likely to be overqualified than a Canadian-born worker. This is the modern face of Canada\'s immigrant employment paradox.';
    }

    // Generic fallback
    else if (prof === 'professional' && edu === 'grad') {
      era = '2015–2025 · The Express Entry Era';
      title = 'High CRS Score — But Watch for the Gap';
      desc = 'Express Entry, introduced in 2015, ranks you highly for your graduate credentials and professional experience. You receive an Invitation to Apply and become a permanent resident. You have done everything right by Canada\'s system. You arrive ready to contribute.';
      verdict = 'The credential recognition system is still fragmented across 13 provincial jurisdictions. There is no national standard. Programs like the Foreign Credential Recognition Program (established 2009) exist but are underfunded and slow. The gap between who Canada selects and how Canada supports them remains the central unresolved challenge of Canadian immigration policy.';
    }

    else {
      era = '1896–1960 · The Agricultural & Industrial Era';
      title = 'Admitted for Manual Labour';
      desc = 'During most of Canada\'s immigration history before 1967, you would have been admitted primarily if you were willing to work in agriculture, construction, or domestic service — regardless of other skills you might have had. The labour hierarchy was clear: farmers first, domestics second, industrial workers third.';
      verdict = 'The skills-based Points System of 1967 was designed to fix this — to admit people based on what they could contribute, not just what category of work they were willing to do. Whether it succeeded is the central question of this project.';
    }

    document.getElementById('result-era').textContent = era;
    document.getElementById('result-title').textContent = title;
    document.getElementById('result-desc').textContent = desc;
    document.getElementById('result-verdict').textContent = verdict;

    document.getElementById('step3').classList.remove('active');
    document.getElementById('result').classList.add('active');
  }

  function restartQuiz() {
    answers = {};
    currentStep = 1;
    document.getElementById('result').classList.remove('active');
    document.querySelectorAll('.quiz-step').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.quiz-option').forEach(b => b.classList.remove('selected'));
    document.querySelectorAll('.quiz-next').forEach(b => b.classList.remove('visible'));
    document.getElementById('step1').classList.add('active');
  }
</script>

